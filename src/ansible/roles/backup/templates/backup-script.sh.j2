#!/bin/bash #

# Log function
# msg: Message to log
# lvl: Log level (INFO, WARN, ERROR)
# log_file: Log file path
# Description: Logs messages with `[LVL] DDMMYY HHMMSS`
log() {
    local msg="$1"
    local lvl="$2"
    local log_file="/var/log/backup/backup.log"
    local timestamp
    timestamp=$(date +"%d%m%y %H%M%S")
    echo "[$lvl] $timestamp : $msg" >> "$log_file"
}

# Function to load .env file from configured env path (from ansible template value bakup_env_path)
load_env() {
    local env_file="{{ backup_env_path }}"
    if [ -f "$env_file" ]; then
        export $(grep -v '^#' "$env_file" | xargs)
        log "Environment variables loaded from $env_file" "INFO"
    else
        log "Environment file $env_file not found. Proceeding without loading env variables." "WARN"
    fi

  # If BACKUP_ENCRYPTION_KEY is not set, throw an error and exit
    if [ -z "$BACKUP_ENCRYPTION_KEY" ]; then
        log "BACKUP_ENCRYPTION_KEY is not set in the environment. Exiting." "ERROR"
        exit 1
    fi
}

# Function to read paths from /etc/backups/paths.txt
read_paths() {
    local paths_file="/etc/backups/paths.txt"
    if [ -f "$paths_file" ]; then
        while IFS= read -r path; do
            # Trim leading/trailing whitespace and ignore empty lines or comments
            [[ -n "$path" && ! "$path" =~ ^[[:space:]]*# ]] && paths_to_backup+=("$path")
        done < "$paths_file"
        if [ ${#paths_to_backup[@]} -eq 0 ]; then
            log "No valid paths found in $paths_file. Exiting." "ERROR"
            exit 1
        fi
    else
        log "File $paths_file not found. Exiting." "ERROR"
        exit 1
    fi
}

# Backup function pt-1 (Ensures temp dir was already done and closed)
# Should create a temp directory that's static. Should be checked to make sure it's empty before use.
# If not empty, log warning, and move contents to backup location with timestamp.
# Then if temp dir is empty proceed with success
backupSTEP1() {
    local temp_dir="/tmp/backup_temp"
    local backup_dest="{{ backup_dir }}"
    
    # Ensure temp directory exists
    mkdir -p "$temp_dir"

    # Check if temp directory is empty
    if [ "$(ls -A $temp_dir)" ]; then
        log "Temporary directory $temp_dir is not empty. Moving contents to backup destination." "WARN"
        local timestamp
        timestamp=$(date +"%Y%m%d_%H%M%S")
        mv "$temp_dir"/* "$backup_dest/partial-backup_$timestamp/"
        log "Moved contents of $temp_dir to $backup_dest/partial-backup_$timestamp/" "INFO"
    else
        log "Temporary directory $temp_dir is empty. Proceeding with backup." "INFO"
    fi
}

# Backup function pt-2
# Tar to archive all the paths specified into their own tar.gz file in temp_dir/zips
# Logging for each path zipped
# No encryption yet
backupSTEP2() {
    local temp_dir="/tmp/backup_temp"
    local zip_dir="$temp_dir/zips"  # Ensure zip_dir is correctly set

    # Create the temporary directory if it doesn't exist
    mkdir -p "$zip_dir"

    for path in "${paths_to_backup[@]}"; do
        if [ -e "$path" ]; then
            local base_name
            base_name=$(basename "$path")
            local timestamp
            timestamp=$(date +"%Y%m%d_%H%M%S")
            local archive_name="$zip_dir/${base_name}_$timestamp.tar.gz"
            tar -czf "$archive_name" "$path"
            if [ $? -eq 0 ]; then
                log "Successfully backed up $path to $archive_name" "INFO"
            else
                log "Failed to back up $path" "ERROR"
            fi
        else
            log "Path $path does not exist. Skipping." "WARN"
        fi
    done
}

# Backup function pt-3
# Zip up all of the other zips into a single zip file with timestamp and encryption BACKUP_ENCRYPTION_KEY
# Add README file with list of paths backed up, timestamps, their expected sizes and hash sums
backupSTEP3() {
    local temp_dir="/tmp/backup_temp"
    local zip_dir="$temp_dir/zips"
    local backup_dest="{{ backup_dir }}"
    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local final_archive="$backup_dest/backup_$timestamp.tar.gz"

    # Create README file
    local readme_file="$temp_dir/README_$timestamp.txt"
    echo "Backup created on: $timestamp" > "$readme_file"
    echo "Paths backed up:" >> "$readme_file"

    for path in "${paths_to_backup[@]}"; do
        if [ -e "$path" ]; then
            local size
            size=$(du -sh "$path" | cut -f1)
            local hash
            hash=$(sha256sum "$path" | awk '{print $1}')
            echo "- $path | Size: $size | SHA256: $hash" >> "$readme_file"
        fi
    done

    # Create final archive with encryption using stronger key derivation method
    tar -czf - -C "$zip_dir" . -C "$temp_dir" . | openssl enc -aes-256-cbc -salt -pbkdf2 -iter 10000 -out "$final_archive" -pass pass:"$BACKUP_ENCRYPTION_KEY"
    if [ $? -eq 0 ]; then
        log "Final encrypted backup created at $final_archive" "INFO"
    else
        log "Failed to create final encrypted backup" "ERROR"
    fi
}

# Backup function pt-4
# Clean up temp directory after successful backup
backupSTEP4() {
    local temp_dir="/tmp/backup_temp"
    rm -rf "$temp_dir"
    if [ $? -eq 0 ]; then
        log "Temporary directory $temp_dir cleaned up successfully." "INFO"
    else
        log "Failed to clean up temporary directory $temp_dir." "ERROR"
    fi
}

# Restore function pt-1
# List available backups in backup destination, make human readable interface with a nice 01-n numbering so the user can pick which one to restore
# Restore the directories to a temp restore directory for inspection before moving to live location
# Exit the script after listing/restoring for manual inspection and leave something in temp directory to restart this restore once
# the user is satisfied. If the function is called and the temp restore directory exists, prompt user to continue with restore or clean up and exit.
# Should unzip the main zip file and decrypt using BACKUP_ENCRYPTION_KEY and unzip all the individual zips in the output temp restore directory
restoreSTEP1() {
    local backup_dest="{{ backup_dir }}"
    local restore_temp_dir="/tmp/backup_restore_temp"
    mkdir -p "$restore_temp_dir"

    echo "Available backups:"
    local backups=("$backup_dest"/*.tar.gz)
    local i=1
    for backup in "${backups[@]}"; do
        echo "$i) $(basename "$backup")"
        i=$((i + 1))
    done

    read -p "Enter the number of the backup to restore: " choice
    local selected_backup="${backups[$((choice - 1))]}"
    if [ -f "$selected_backup" ]; then
        openssl enc -d -aes-256-cbc -in "$selected_backup" -pass pass:"$BACKUP_ENCRYPTION_KEY" | tar -xz -C "$restore_temp_dir"
        if [ $? -eq 0 ]; then
            log "Backup $selected_backup restored to $restore_temp_dir for inspection." "INFO"
            echo "Backup restored to $restore_temp_dir. Please inspect the files before moving them to their live locations."
        else
            log "Failed to restore backup $selected_backup." "ERROR"
        fi
    else
        log "Invalid selection. No such backup." "ERROR"
    fi

    log "Backup script completed successfully." "INFO"
}

# Main function, takes arguments to start or finish backups.
function main() {
    local action=$1
    load_env
    read_paths
    
    if [ "$action" == "backup" ]; then
        # Uncomment the following lines to enable backup steps
        log "Starting backup process..." "INFO"
        backupSTEP1
        backupSTEP2
        backupSTEP3
        backupSTEP4
    elif [ "$action" == "restore" ]; then
        log "Starting restore process..." "INFO"
        restoreSTEP1
    else
        log "Invalid action. Please provide either 'backup' or 'restore'." "ERROR"
        exit 1
    fi
}

main "$@"
